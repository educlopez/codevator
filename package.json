{
  "name": "codevator-monorepo",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:cli": "pnpm --filter codevator dev",
    "dev:menubar": "pnpm --filter @codevator/menubar dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter web build",
    "build:cli": "pnpm --filter codevator build",
    "build:menubar": "pnpm --filter @codevator/menubar build",
    "pack:menubar": "pnpm --filter @codevator/menubar pack",
    "test": "pnpm -r test",
    "release": "pnpm --filter codevator release"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver"],
    "overrides": {
      "undici": ">=6.24.0",
      "flatted": ">=3.4.2",
      "minimatch": ">=3.1.4",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "ajv@<6.14.0": "6.14.0",
      "lodash@>=4.0.0 <4.18.0": "4.18.0",
      "basic-ftp@<5.3.0": "5.3.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "vite@>=7.0.0 <7.3.2": "7.3.2",
      "handlebars@>=4.0.0 <4.7.9": "4.7.9",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5"
    }
  }
}
