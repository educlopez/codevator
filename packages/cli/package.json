{
  "name": "codevator",
  "version": "0.9.0",
  "type": "module",
  "description": "Elevator music for your AI coding agent",
  "bin": {
    "codevator": "dist/bin.js"
  },
  "files": [
    "dist",
    "sounds/elevator.mp3",
    "skill"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "GITHUB_TOKEN=$(gh auth token) release-it && gh release create v$(node -p \"require('./package.json').version\") --generate-notes && npm publish --auth-type=web"
  },
  "keywords": [
    "claude",
    "ai",
    "music",
    "elevator",
    "coding",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.0",
    "release-it": "^18.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
